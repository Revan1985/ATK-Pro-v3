#!/bin/sh
set -e

if [ "$1" = "configure" ]; then

    # Read language chosen by preinst
    # Nota: preinst scrive in /var/tmp/ (non /tmp/) perche' apt-daemon ha
    # PrivateTmp=yes e i file in /tmp/ non sono visibili al postinst.
    SELECTED_LANG="en"
    if [ -f /var/tmp/atk-pro-install-lang ]; then
        SELECTED_LANG=$(cat /var/tmp/atk-pro-install-lang)
        rm -f /var/tmp/atk-pro-install-lang
    fi

    # Write system-wide config (fallback for all users / polkit installs)
    mkdir -p /etc/atk-pro
    printf '{"language": "%s"}\n' "$SELECTED_LANG" > /etc/atk-pro/defaults.json
    echo "ATK-Pro: system language default set to '$SELECTED_LANG'"

    # Detect real user: sudo -> polkit/pkexec -> logname -> who
    ACTUAL_USER="${SUDO_USER:-}"
    if [ -z "$ACTUAL_USER" ] && [ -n "${PKEXEC_UID:-}" ]; then
        ACTUAL_USER=$(getent passwd "$PKEXEC_UID" | cut -d: -f1 2>/dev/null || true)
    fi
    if [ -z "$ACTUAL_USER" ]; then
        ACTUAL_USER=$(logname 2>/dev/null || true)
    fi
    if [ -z "$ACTUAL_USER" ]; then
        ACTUAL_USER=$(who | awk 'NR==1{print $1}' 2>/dev/null || true)
    fi

    if [ -n "$ACTUAL_USER" ] && id "$ACTUAL_USER" >/dev/null 2>&1; then
        USER_HOME=$(getent passwd "$ACTUAL_USER" | cut -d: -f6)
        CONFIG_DIR="$USER_HOME/.config/atk-pro"
        mkdir -p "$CONFIG_DIR"
        printf '{"language": "%s"}\n' "$SELECTED_LANG" > "$CONFIG_DIR/config.json"
        chown -R "$ACTUAL_USER" "$CONFIG_DIR" 2>/dev/null || true
        echo "ATK-Pro: language '$SELECTED_LANG' saved for user $ACTUAL_USER"
    else
        echo "ATK-Pro: could not detect real user -- language saved system-wide only"
    fi

    # Update desktop database and icon cache
    if command -v update-desktop-database > /dev/null 2>&1; then
        update-desktop-database /usr/share/applications || true
    fi
    if command -v gtk-update-icon-cache > /dev/null 2>&1; then
        gtk-update-icon-cache -f -t /usr/share/icons/hicolor || true
    fi
fi
