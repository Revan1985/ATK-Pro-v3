DISCLAIMER_EOF

    printf '\n\nAccetti le condizioni sopra riportate? [si/no]: ' >&3
    read REPLY <&4

    case "$REPLY" in
        si|SI|Si|yes|YES|Yes|y|Y)
            printf 'Accettato.\n\n' >&3
            ;;
        *)
            printf 'Installazione annullata: termini non accettati.\n' >&3
            exit 1
            ;;
    esac

    # ── Scelta lingua ───────────────────────────────────────────────────────
    printf 'Lingue disponibili: %s\n' "$LANGS" >&3
    printf 'Seleziona la lingua predefinita [en]: ' >&3
    read LANG_CHOICE <&4

    # Valida
    LANG_CHOICE="${LANG_CHOICE:-en}"
    VALID=0
    for L in $LANGS; do
        if [ "$LANG_CHOICE" = "$L" ]; then
            VALID=1
            break
        fi
    done
    if [ "$VALID" = "0" ]; then
        printf 'Lingua non valida, uso "en" come predefinito.\n' >&3
        LANG_CHOICE="en"
    fi

    printf 'Lingua selezionata: %s\n\n' "$LANG_CHOICE" >&3

    # Salva in /tmp per postinst
    printf '%s' "$LANG_CHOICE" > /tmp/atk-pro-install-lang

    exec 3>&-
    exec 4<&-
fi
