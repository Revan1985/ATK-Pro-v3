#!/bin/sh
set -e

# -----------------------------------------------------------------------
# Strategia disclaimer e selezione lingua:
#
# Il disclaimer e la selezione lingua vengono sempre mostrati al primo
# avvio dell'applicazione tramite interfaccia grafica Qt nativa.
#
# Questo approccio garantisce il corretto funzionamento con qualsiasi
# metodo di installazione:
#   - GDebi, GNOME Software, Discover, Ubuntu Software Center
#   - sudo dpkg -i / sudo apt install (terminale)
#   - PackageKit, Synaptic, qualsiasi frontend APT
#
# GDebi e altri installer GUI allocano una pseudo-TTY per gli script
# di pacchetto: un approccio interattivo su /dev/tty risulterebbe
# invisibile all'utente (visibile solo nel pannello "Dettagli").
# -----------------------------------------------------------------------

if [ "$1" = "install" ] || [ "$1" = "upgrade" ]; then
    # Scrivi flag: al primo avvio l'app mostra disclaimer e selezione lingua.
    mkdir -p /var/lib/atk-pro
    touch /var/lib/atk-pro/pending-disclaimer
    chmod 0666 /var/lib/atk-pro/pending-disclaimer
    chmod 0777 /var/lib/atk-pro
    # Lingua di default per il postinst (l'utente potra cambiarla al primo avvio)
    printf 'en' > /tmp/atk-pro-install-lang
fi