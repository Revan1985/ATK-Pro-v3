DISCLAIMER_EOF

    printf '\n\nDo you accept the terms above? [yes/no]: ' >&3
    read REPLY <&4

    case "$REPLY" in
        yes|YES|Yes|y|Y|si|SI|Si)
            printf 'Accepted.\n\n' >&3
            ;;
        *)
            printf 'Installation aborted: terms not accepted.\n' >&3
            exit 1
            ;;
    esac

    # -- Language selection ----------------------------------------------------
    printf 'Available languages: %s\n' "$LANGS" >&3
    printf 'Select default language [en]: ' >&3
    read LANG_CHOICE <&4

    # Validate
    LANG_CHOICE="${LANG_CHOICE:-en}"
    VALID=0
    for L in $LANGS; do
        if [ "$LANG_CHOICE" = "$L" ]; then
            VALID=1
            break
        fi
    done
    if [ "$VALID" = "0" ]; then
        printf 'Invalid language code, using "en" as default.\n' >&3
        LANG_CHOICE="en"
    fi

    printf 'Selected language: %s\n\n' "$LANG_CHOICE" >&3

    # Save for postinst
    printf '%s' "$LANG_CHOICE" > /tmp/atk-pro-install-lang

    exec 3>&-
    exec 4<&-
fi
