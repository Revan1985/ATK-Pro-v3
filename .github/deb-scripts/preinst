#!/bin/sh
set -e

LANGS="it en es de fr pt nl ar he ru da el ja no pl ro sv tr vi zh"

if [ "$1" = "install" ] || [ "$1" = "upgrade" ]; then

    # -- Show disclaimer -------------------------------------------------------
    # Use /dev/tty for direct terminal I/O (works with dpkg -i, apt, gdebi)
    if [ -e /dev/tty ]; then
        exec 3>/dev/tty
        exec 4</dev/tty
    else
        exec 3>&1
        exec 4<&0
    fi

    cat >&3 <<'DISCLAIMER_EOF'
📋 Legal Disclaimer
Antenati Toolkit Pro

ATK-Pro – Antenati Toolkit Pro
