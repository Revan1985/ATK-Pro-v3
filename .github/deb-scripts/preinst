#!/bin/sh
set -e

# -----------------------------------------------------------------------
# Strategia disclaimer:
#
# 1. PERCORSO INTERATTIVO (sudo dpkg -i, apt, GDebi):
#    Il file config ha gia' chiesto lingua + accettazione via debconf.
#    Se l'utente risponde "No" -> exit 1 -> dpkg annulla installazione.
#
# 2. PERCORSO NONINTERACTIVE (Software Manager, Nemo double-click, etc.):
#    Il config ha tentato zenity se DISPLAY disponibile.
#    - Se l'utente ha accettato in zenity: accept-disclaimer=true -> OK
#    - Se ha rifiutato, o non c'era display/zenity: rimane false -> exit 1
#    -> In questo secondo caso il messaggio indica di usare il terminale.
#
# 3. FALLBACK (debconf non disponibile, caso rarissimo):
#    Scrivi pending-disclaimer flag (app mostra disclaimer al primo avvio).
# -----------------------------------------------------------------------

if [ "$1" = "install" ]; then
    if [ -f /usr/share/debconf/confmodule ]; then
        . /usr/share/debconf/confmodule

        db_get atk-pro/accept-disclaimer || RET="false"
        _ACCEPTED="$RET"

        if [ "$_ACCEPTED" != "true" ]; then
            # ----------------------------------------------------------------
            # Il disclaimer non e' stato accettato via debconf (frontend
            # noninteractive: Software Manager, doppio click su .deb).
            # Proviamo a mostrare zenity come utente della sessione desktop.
            # ----------------------------------------------------------------
            _ZENITY_ACCEPTED=0

            # --- Rilevamento utente ---
            _LOGIN_USER=""

            # Metodo 1: loginctl (systemd, affidabile su Mint/Ubuntu moderni)
            if command -v loginctl >/dev/null 2>&1; then
                _LOGIN_USER=$(loginctl list-sessions --no-legend 2>/dev/null | \
                    awk 'NF>=4 && $4!="root" && $4!="" {print $4; exit}')
            fi

            # Metodo 2: who
            if [ -z "$_LOGIN_USER" ]; then
                _LOGIN_USER=$(who 2>/dev/null | awk 'NR==1{print $1}')
            fi

            # Metodo 3: proprietario del processo compositor (filtra per utente)
            if [ -z "$_LOGIN_USER" ]; then
                for _prog in cinnamon gnome-shell plasmashell xfce4-session openbox muffin; do
                    _pid=$(pgrep -x "$_prog" 2>/dev/null | head -1)
                    [ -z "$_pid" ] && continue
                    _uid=$(awk '/^Uid:/{print $2}' /proc/$_pid/status 2>/dev/null)
                    [ -z "$_uid" ] || [ "$_uid" = "0" ] && continue
                    _LOGIN_USER=$(getent passwd "$_uid" 2>/dev/null | cut -d: -f1)
                    [ -n "$_LOGIN_USER" ] && break
                done
            fi

            # Metodo 4: prima directory in /home
            if [ -z "$_LOGIN_USER" ]; then
                _LOGIN_USER=$(find /home -maxdepth 1 -mindepth 1 -type d 2>/dev/null | head -1 | xargs basename 2>/dev/null)
            fi

            # --- Rilevamento DISPLAY/XAUTHORITY ---
            _DISP=""; _XAUTH=""

            # Da /proc: filtra per utente per evitare falsi positivi
            if [ -n "$_LOGIN_USER" ]; then
                for _prog in cinnamon gnome-shell plasmashell xfce4-session openbox kwin_x11 muffin; do
                    _pid=$(pgrep -u "$_LOGIN_USER" -x "$_prog" 2>/dev/null | head -1)
                    [ -z "$_pid" ] && continue
                    _penv=$(tr '\0' '\n' < /proc/$_pid/environ 2>/dev/null)
                    [ -z "$_DISP" ]  && _DISP=$(printf '%s\n' "$_penv"  | grep '^DISPLAY='    | head -1 | cut -d= -f2-)
                    [ -z "$_XAUTH" ] && _XAUTH=$(printf '%s\n' "$_penv" | grep '^XAUTHORITY=' | head -1 | cut -d= -f2-)
                    [ -n "$_DISP" ] && break
                done
            fi

            # Fallback: :0 (la grande maggioranza dei sistemi single-user Xorg)
            [ -z "$_DISP" ] && _DISP=":0"

            # Fallback XAUTHORITY: ~/.Xauthority
            if [ -z "$_XAUTH" ] && [ -n "$_LOGIN_USER" ]; then
                _UHOME=$(getent passwd "$_LOGIN_USER" 2>/dev/null | cut -d: -f6)
                [ -n "$_UHOME" ] && [ -f "$_UHOME/.Xauthority" ] && _XAUTH="$_UHOME/.Xauthority"
            fi

            if [ -n "$_LOGIN_USER" ] && command -v zenity >/dev/null 2>&1; then
                # ---- Selezione lingua utente (in noninteractive config l'ha saltata) ----
                _TMPSH_LANG=$(mktemp /tmp/atk-pro-lang-XXXXXX.sh)
                {
                    printf '#!/bin/sh\n'
                    printf 'export DISPLAY="%s"\n' "$_DISP"
                    [ -n "$_XAUTH" ] && printf 'export XAUTHORITY="%s"\n' "$_XAUTH"
                    printf 'exec zenity --list --radiolist'
                    printf ' --title="ATK-Pro - Select Language / Seleziona Lingua"'
                    printf ' --column="" --column="Code" --column="Language"'
                    printf ' --print-column=2'
                    printf ' FALSE ar Arabic'
                    printf ' FALSE da Dansk'
                    printf ' FALSE de Deutsch'
                    printf ' FALSE el Greek'
                    printf ' TRUE  en English'
                    printf ' FALSE es Espanol'
                    printf ' FALSE fr Francais'
                    printf ' FALSE he Hebrew'
                    printf ' FALSE it Italiano'
                    printf ' FALSE ja Japanese'
                    printf ' FALSE nl Nederlands'
                    printf ' FALSE no Norsk'
                    printf ' FALSE pl Polski'
                    printf ' FALSE pt Portugues'
                    printf ' FALSE ro Romana'
                    printf ' FALSE ru Russian'
                    printf ' FALSE sv Svenska'
                    printf ' FALSE tr Turkce'
                    printf ' FALSE vi Vietnamese'
                    printf ' FALSE zh Chinese'
                    printf ' --width=380 --height=520\n'
                } > "$_TMPSH_LANG"
                chmod 755 "$_TMPSH_LANG"
                chown "$_LOGIN_USER" "$_TMPSH_LANG" 2>/dev/null || true

                _CHOSEN_LANG=""
                if command -v runuser >/dev/null 2>&1; then
                    _CHOSEN_LANG=$(runuser -u "$_LOGIN_USER" -- /bin/sh "$_TMPSH_LANG" 2>/dev/null)
                else
                    _CHOSEN_LANG=$(su "$_LOGIN_USER" -s /bin/sh -- "$_TMPSH_LANG" 2>/dev/null)
                fi
                rm -f "$_TMPSH_LANG"

                # Valida il codice scelto; default: en
                case "$_CHOSEN_LANG" in
                    ar|da|de|el|en|es|fr|he|it|ja|nl|no|pl|pt|ro|ru|sv|tr|vi|zh) ;;
                    *) _CHOSEN_LANG=en ;;
                esac
                printf '%s' "$_CHOSEN_LANG" > /tmp/atk-pro-install-lang

                # Scrivi il testo disclaimer su file temp.
                # db_metaget restituisce solo la prima riga via $RET (limite IPC);
                # usiamo perl/debconf per leggere il testo completo multi-riga.
                _TMPDISC=$(mktemp /tmp/atk-pro-disc-XXXXXX.txt)

                # Titolo (prima riga di Description)
                db_metaget atk-pro/accept-disclaimer description 2>/dev/null \
                    && printf '%s\n\n' "$RET" > "$_TMPDISC" || true

                # Corpo completo: perl legge dal database debconf senza il limite IPC
                perl -e '
                    use Debconf::Db;
                    Debconf::Db->load;
                    my $q = Debconf::Config->getInstance->question("atk-pro/accept-disclaimer");
                    if ($q) {
                        my $desc = $q->getfield("extended_description") // "";
                        $desc =~ s/^ \.$//mg;
                        $desc =~ s/^ //mg;
                        print $desc, "\n";
                    }
                ' 2>/dev/null >> "$_TMPDISC" || true

                # Fallback: se perl non ha prodotto output, leggi dal templates staged
                if [ ! -s "$_TMPDISC" ]; then
                    _SCRIPT_DIR=$(dirname "$(readlink -f "$0")" 2>/dev/null || dirname "$0")
                    if [ -f "$_SCRIPT_DIR/templates" ]; then
                        # Estrae il blocco extended_description dalla lingua di sistema
                        awk '
                            /^Template: atk-pro\/accept-disclaimer/{found=1; next}
                            found && /^Description:/{body=1; next}
                            found && body && /^ /{
                                line=$0; sub(/^ \. *$/,"",line); sub(/^ /,"",line)
                                print line
                                next
                            }
                            found && body && /^[^ ]/{exit}
                        ' "$_SCRIPT_DIR/templates" >> "$_TMPDISC" 2>/dev/null || true
                    fi
                fi

                # Secondo fallback: URL del progetto
                [ -s "$_TMPDISC" ] || printf 'ATK-Pro Legal Disclaimer\n\nhttps://github.com/DanielePigoli/ATK-Pro-v2\n' > "$_TMPDISC"

                chmod 644 "$_TMPDISC"
                chown "$_LOGIN_USER" "$_TMPDISC" 2>/dev/null || true

                # Usa script temporaneo per evitare problemi di quoting con su/runuser
                _TMPSH=$(mktemp /tmp/atk-pro-zen-XXXXXX.sh)
                {
                    printf '#!/bin/sh\n'
                    printf 'export DISPLAY="%s"\n' "$_DISP"
                    [ -n "$_XAUTH" ] && printf 'export XAUTHORITY="%s"\n' "$_XAUTH"
                    printf 'exec zenity --text-info'
                    printf ' --title="ATK-Pro Legal Disclaimer"'
                    printf ' --filename="%s"' "$_TMPDISC"
                    printf ' --ok-label="Accept / Accetto"'
                    printf ' --cancel-label="Decline / Rifiuto"'
                    printf ' --width=750 --height=600\n'
                } > "$_TMPSH"
                chmod 755 "$_TMPSH"
                chown "$_LOGIN_USER" "$_TMPSH" 2>/dev/null || true

                # Lancia come utente reale (runuser preferito su Debian/Ubuntu/Mint)
                if command -v runuser >/dev/null 2>&1; then
                    runuser -u "$_LOGIN_USER" -- /bin/sh "$_TMPSH" 2>/dev/null && _ZENITY_ACCEPTED=1
                else
                    su "$_LOGIN_USER" -s /bin/sh -- "$_TMPSH" 2>/dev/null && _ZENITY_ACCEPTED=1
                fi

                rm -f "$_TMPDISC" "$_TMPSH"
            fi

            if [ "$_ZENITY_ACCEPTED" = "0" ]; then
            # Disclaimer non accettato o impossibile mostrare: blocca installazione
            _LANG="en"
            if [ -f /tmp/atk-pro-install-lang ]; then
                _LANG="$(cat /tmp/atk-pro-install-lang)"
            fi
            echo "" >&2
            case "$_LANG" in
                it)
                    echo "  ATK-Pro: installazione annullata." >&2
                    echo "  E' necessario accettare il disclaimer legale per installare ATK-Pro." >&2
                    echo "  Usa 'sudo dpkg -i atk-pro_*.deb' oppure GDebi per completare l'installazione." >&2
                    ;;
                de)
                    echo "  ATK-Pro: Installation abgebrochen." >&2
                    echo "  Sie muessen den rechtlichen Haftungsausschluss akzeptieren, um ATK-Pro zu installieren." >&2
                    echo "  Verwenden Sie 'sudo dpkg -i atk-pro_*.deb' oder GDebi, um die Installation abzuschliessen." >&2
                    ;;
                es)
                    echo "  ATK-Pro: instalacion cancelada." >&2
                    echo "  Debe aceptar el descargo de responsabilidad legal para instalar ATK-Pro." >&2
                    echo "  Use 'sudo dpkg -i atk-pro_*.deb' o GDebi para completar la instalacion." >&2
                    ;;
                fr)
                    echo "  ATK-Pro: installation annulee." >&2
                    echo "  Vous devez accepter la clause de non-responsabilite pour installer ATK-Pro." >&2
                    echo "  Utilisez 'sudo dpkg -i atk-pro_*.deb' ou GDebi pour completer l'installation." >&2
                    ;;
                pt)
                    echo "  ATK-Pro: instalacao cancelada." >&2
                    echo "  E necessario aceitar o aviso legal para instalar o ATK-Pro." >&2
                    echo "  Use 'sudo dpkg -i atk-pro_*.deb' ou GDebi para concluir a instalacao." >&2
                    ;;
                nl)
                    echo "  ATK-Pro: installatie geannuleerd." >&2
                    echo "  U moet de juridische disclaimer accepteren om ATK-Pro te installeren." >&2
                    echo "  Gebruik 'sudo dpkg -i atk-pro_*.deb' of GDebi om de installatie te voltooien." >&2
                    ;;
                ru)
                    echo "  ATK-Pro: ustanovka otmenena." >&2
                    echo "  Dlya ustanovki ATK-Pro neobkhodimo prinyat pravovuyu ogovorku." >&2
                    echo "  Ispolzujte 'sudo dpkg -i atk-pro_*.deb' ili GDebi dlya zavershenia ustanovki." >&2
                    ;;
                da)
                    echo "  ATK-Pro: installation annulleret." >&2
                    echo "  Du skal acceptere den juridiske ansvarsfraskrivelse for at installere ATK-Pro." >&2
                    echo "  Brug 'sudo dpkg -i atk-pro_*.deb' eller GDebi til at fuldfoere installationen." >&2
                    ;;
                el)
                    echo "  ATK-Pro: egkatastasi akyrothike." >&2
                    echo "  Prepei na apodechteite tin anakoinosi apopoiseis eythynis gia egkatastasi." >&2
                    echo "  Chrisimopoiiste 'sudo dpkg -i atk-pro_*.deb' i GDebi." >&2
                    ;;
                ja)
                    echo "  ATK-Pro: installation ga chyushi saremashita." >&2
                    echo "  ATK-Pro wo install suru niwa houteki menzetsu jiko wo douri shite kudasai." >&2
                    echo "  'sudo dpkg -i atk-pro_*.deb' matawa GDebi wo shiyou shite kudasai." >&2
                    ;;
                no)
                    echo "  ATK-Pro: installasjon avbrutt." >&2
                    echo "  Du ma godta den juridiske ansvarsfraskrivelsen for a installere ATK-Pro." >&2
                    echo "  Bruk 'sudo dpkg -i atk-pro_*.deb' eller GDebi for a fullfoere installasjonen." >&2
                    ;;
                pl)
                    echo "  ATK-Pro: instalacja anulowana." >&2
                    echo "  Aby zainstalowac ATK-Pro, nalezy zaakceptowac zastrzezenie prawne." >&2
                    echo "  Uzyj 'sudo dpkg -i atk-pro_*.deb' lub GDebi, aby zakonczyc instalacje." >&2
                    ;;
                ro)
                    echo "  ATK-Pro: instalare anulata." >&2
                    echo "  Trebuie sa acceptati declaratia legala pentru a instala ATK-Pro." >&2
                    echo "  Folositi 'sudo dpkg -i atk-pro_*.deb' sau GDebi pentru a finaliza instalarea." >&2
                    ;;
                sv)
                    echo "  ATK-Pro: installation avbruten." >&2
                    echo "  Du maste acceptera den juridiska ansvarsfriskrivningen for att installera ATK-Pro." >&2
                    echo "  Anvand 'sudo dpkg -i atk-pro_*.deb' eller GDebi for att slutfora installationen." >&2
                    ;;
                tr)
                    echo "  ATK-Pro: kurulum iptal edildi." >&2
                    echo "  ATK-Pro kurulumu icin yasal sorumluluk reddini kabul etmeniz gerekiyor." >&2
                    echo "  Kurulumu tamamlamak icin 'sudo dpkg -i atk-pro_*.deb' veya GDebi kullanin." >&2
                    ;;
                vi)
                    echo "  ATK-Pro: cai dat bi huy." >&2
                    echo "  Ban phai chap nhan tuyen bo mien trach nhiem phap ly de cai dat ATK-Pro." >&2
                    echo "  Su dung 'sudo dpkg -i atk-pro_*.deb' hoac GDebi de hoan tat cai dat." >&2
                    ;;
                zh)
                    echo "  ATK-Pro: an zhuang yi qu xiao." >&2
                    echo "  nin xu yao jie shou fa lv mian ze sheng ming cai neng an zhuang ATK-Pro." >&2
                    echo "  qing shi yong 'sudo dpkg -i atk-pro_*.deb' huo GDebi wan cheng an zhuang." >&2
                    ;;
                ar)
                    echo "  ATK-Pro: tamma ilgha al-tathbit." >&2
                    echo "  Yajib an tuwafiqa ala ikhla al-masouliyya al-qanuniyya lil-tathbit." >&2
                    echo "  Istakhdim 'sudo dpkg -i atk-pro_*.deb' aw GDebi li-ikmal al-tathbit." >&2
                    ;;
                he)
                    echo "  ATK-Pro: hahatkata butla." >&2
                    echo "  Yesh lekabel et ktvat hahavtara hamishpatit kedei lehatkhin et ATK-Pro." >&2
                    echo "  Hashtemsh be-'sudo dpkg -i atk-pro_*.deb' o GDebi lehashlem." >&2
                    ;;
                *)  # en e fallback
                        echo "  ATK-Pro: installation cancelled." >&2
                        echo "  You must accept the legal disclaimer to install ATK-Pro." >&2
                        echo "  Use 'sudo dpkg -i atk-pro_*.deb' or GDebi to complete the installation." >&2
                        ;;
                esac
                echo "" >&2
                exit 1
            fi  # end _ZENITY_ACCEPTED = 0
        fi  # end _ACCEPTED != true
    else
        # debconf non disponibile: fallback con pending flag
        mkdir -p /var/lib/atk-pro
        touch /var/lib/atk-pro/pending-disclaimer
        chmod 0666 /var/lib/atk-pro/pending-disclaimer
        chmod 0777 /var/lib/atk-pro
    fi
elif [ "$1" = "upgrade" ]; then
    # Upgrade: non richiedere di nuovo l'accettazione
    :
fi

# Lingua di default per postinst (scritta da config durante install;
# durante upgrade impostiamo 'en' come fallback se il file non esiste)
if [ "$1" = "upgrade" ] && [ ! -f /tmp/atk-pro-install-lang ]; then
    printf 'en' > /tmp/atk-pro-install-lang
fi