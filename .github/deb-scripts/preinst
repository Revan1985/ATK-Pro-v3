#!/bin/sh
set -e

LANGS="it en es de fr pt nl ar he ru da el ja no pl ro sv tr vi zh"

if [ "$1" = "install" ] || [ "$1" = "upgrade" ]; then

    LANG_CHOICE=""

    # -----------------------------------------------------------------------
    # Strategia disclaimer:
    #
    #  A) Installazione da TERMINALE (sudo dpkg -i, sudo apt install ...):
    #     /dev/tty e accessibile -> mostra disclaimer e selezione lingua
    #     direttamente nel terminale via /dev/tty.
    #
    #  B) Installazione da GUI (GDebi, Software Manager, GNOME Software,
    #     PackageKit, qualsiasi installer grafico):
    #     preinst gira come root via pkexec/polkit SENZA un terminale di
    #     controllo reale. Anche se DISPLAY e impostato nell'ambiente, i
    #     tool grafici (zenity, kdialog) vengono eseguiti come root e NON
    #     possono aprire il display dell'utente -> si bloccano a tempo
    #     indefinito causando il freeze dell'installer.
    #     Soluzione: scrive il flag /var/lib/atk-pro/pending-disclaimer e
    #     termina subito (exit 0). L'app mostrera il disclaimer al primo
    #     avvio grafico in modo nativo con Qt, nella lingua dell'utente.
    # -----------------------------------------------------------------------

    _have_tty=0
    if [ -e /dev/tty ]; then
        if ( exec 5>/dev/tty ) 2>/dev/null; then
            _have_tty=1
        fi
    fi

    if [ "$_have_tty" = "0" ]; then
        # Caso B: installer grafico o daemon senza tty.
        # Scrivi flag: l'app mostrera il disclaimer al primo avvio.
        mkdir -p /var/lib/atk-pro
        touch /var/lib/atk-pro/pending-disclaimer
        chmod 0666 /var/lib/atk-pro/pending-disclaimer
        chmod 0777 /var/lib/atk-pro
        printf 'en' > /tmp/atk-pro-install-lang
        exit 0
    fi

    # Caso A: terminale reale disponibile -> disclaimer testuale su /dev/tty
    exec 3>/dev/tty
    exec 4</dev/tty

    cat >&3 <<'DISCLAIMER_EOF'

========================================================
 ATK-Pro - Legal Disclaimer and Ethical Use Commitment
========================================================

The ATK-Pro project is designed for archival, genealogical, and
consultation purposes. All content, unless otherwise stated, is
distributed under a Creative Commons BY-NC-SA 4.0 license.
Direct commercial use, redistribution without attribution, or
untracked modification of the original content is prohibited.
ATK-Pro does not redistribute any content from the Antenati Portal
(antenati.cultura.gov.it) nor does it intend to replicate its
interface, structure, or organization.
Anyone who installs or uses ATK-Pro agrees to act in full compliance
with the legal notices defined by the Ministry of Culture, available at:
https://antenati.cultura.gov.it/note-legali/

The author disclaims any responsibility regarding the improper use,
misinterpretation, or unauthorized modification of the included
documents and tools.

(c) 2026 Antenati Toolkit Pro | Version 2.0
antenati.toolkit.pro@gmail.com

DISCLAIMER_EOF

    printf 'Do you accept the terms above? [yes/no]: ' >&3
    read REPLY <&4

    case "$REPLY" in
        yes|YES|Yes|y|Y|si|SI|Si)
            printf 'Accepted.\n\n' >&3
            ;;
        *)
            printf 'Installation aborted: terms not accepted.\n' >&3
            exec 3>&-
            exec 4<&-
            exit 1
            ;;
    esac

    printf 'Available languages: %s\n' "$LANGS" >&3
    printf 'Select default language [en]: ' >&3
    read LANG_CHOICE <&4

    exec 3>&-
    exec 4<&-

    # -- Valida lingua scelta -----------------------------------------------
    LANG_CHOICE="${LANG_CHOICE:-en}"
    VALID=0
    for L in $LANGS; do
        if [ "$LANG_CHOICE" = "$L" ]; then
            VALID=1
            break
        fi
    done
    if [ "$VALID" = "0" ]; then
        LANG_CHOICE="en"
    fi

    # Salva per postinst
    printf '%s' "$LANG_CHOICE" > /tmp/atk-pro-install-lang

fi