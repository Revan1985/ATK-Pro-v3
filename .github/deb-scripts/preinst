                ACCEPTED=1
                ;;
            *)
                printf 'Installation aborted: terms not accepted.\n' >&3
                exit 1
                ;;
        esac

        printf 'Available languages: %s\n' "$LANGS" >&3
        printf 'Select default language [en]: ' >&3
        read LANG_CHOICE <&4

        exec 3>&-
        exec 4<&-
    fi

    # -- Valida lingua scelta -----------------------------------------------
    LANG_CHOICE="${LANG_CHOICE:-en}"
    VALID=0
    for L in $LANGS; do
        if [ "$LANG_CHOICE" = "$L" ]; then
            VALID=1
            break
        fi
    done
    if [ "$VALID" = "0" ]; then
        LANG_CHOICE="en"
    fi

    # Salva per postinst
