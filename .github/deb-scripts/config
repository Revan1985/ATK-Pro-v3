#!/bin/sh
# debconf config: viene eseguito da dpkg PRIMA di preinst.
# Chiede l'accettazione del disclaimer via debconf (readline su terminale,
# dialog GTK su GDebi, dialog Qt su KDE). Solo per nuove installazioni.
set -e
. /usr/share/debconf/confmodule
db_version 2.0

if [ "$1" = "install" ]; then
    db_input high atk-pro/accept-disclaimer || true
    db_go || true
fi
