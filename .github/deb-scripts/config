#!/bin/sh
# debconf config: viene eseguito da dpkg PRIMA di preinst.
# Chiede lingua e disclaimer via debconf (funziona con terminale e GDebi).
# Per frontend noninteractive (Software Manager / doppio click), le db_input
# sono silenziosamente ignorate; preinst gestira' il disclaimer tramite zenity
# rilevando DISPLAY direttamente dai processi della sessione desktop.
set -e
. /usr/share/debconf/confmodule
db_version 2.0

if [ "$1" = "install" ]; then
    # Resetta i flag "seen" per forzare la richiesta anche in caso di reinstallazione
    # (senza db_fset, debconf ricorderebbe le risposte precedenti e salterebbe le domande)
    db_fset atk-pro/language seen false || true
    db_fset atk-pro/accept-disclaimer seen false || true

    # Selezione lingua (silenziosa se frontend noninteractive)
    db_input high atk-pro/language || true
    db_go || true

    db_get atk-pro/language || true
    LANG_CHOSEN="${RET:-en}"
    # Usa /var/tmp/ (non /tmp/): apt-daemon ha PrivateTmp=yes, /tmp/ non e' visibile a postinst
    printf '%s' "$LANG_CHOSEN" > /var/tmp/atk-pro-install-lang

    # Imposta locale per traduzione disclaimer debconf
    case "$LANG_CHOSEN" in
        ar)  export LANG=ar_SA.UTF-8 ;;
        da)  export LANG=da_DK.UTF-8 ;;
        de)  export LANG=de_DE.UTF-8 ;;
        el)  export LANG=el_GR.UTF-8 ;;
        es)  export LANG=es_ES.UTF-8 ;;
        fr)  export LANG=fr_FR.UTF-8 ;;
        he)  export LANG=he_IL.UTF-8 ;;
        it)  export LANG=it_IT.UTF-8 ;;
        ja)  export LANG=ja_JP.UTF-8 ;;
        nl)  export LANG=nl_NL.UTF-8 ;;
        no)  export LANG=nb_NO.UTF-8 ;;
        pl)  export LANG=pl_PL.UTF-8 ;;
        pt)  export LANG=pt_PT.UTF-8 ;;
        ro)  export LANG=ro_RO.UTF-8 ;;
        ru)  export LANG=ru_RU.UTF-8 ;;
        sv)  export LANG=sv_SE.UTF-8 ;;
        tr)  export LANG=tr_TR.UTF-8 ;;
        vi)  export LANG=vi_VN.UTF-8 ;;
        zh)  export LANG=zh_CN.UTF-8 ;;
        *)   export LANG=en_US.UTF-8 ;;
    esac
    export LC_ALL="$LANG"

    # Disclaimer via debconf (silenzioso se noninteractive)
    db_input high atk-pro/accept-disclaimer || true
    db_go || true
fi
